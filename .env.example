# --- Copy to .env and adjust ------------------------------------------------

# PostgreSQL
POSTGRES_USER=cybersim
POSTGRES_PASSWORD=cybersim
POSTGRES_DB=cybersim

# OpenAI (AI Explainer). Leave blank to use the built-in offline explanations.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SecureWatch SIEM integration.
# CyberSim POSTs every attack event to this webhook so the SIEM can correlate
# the attack with its own detection. Leave blank to disable forwarding.
SECUREWATCH_WEBHOOK_URL=
SECUREWATCH_API_KEY=

# Safety allowlist. Comma-separated hostnames/IPs that attacks may target.
# These are the ONLY destinations accepted by the engine. Anything else is
# rejected before a single packet is sent.
TARGET_ALLOWLIST=dvwa,vuln-node-api,weak-ssh,localhost,127.0.0.1,cybersim-dvwa,cybersim-vuln-node,cybersim-weak-ssh
